#!/usr/bin/env python3
"""Run alembic migrations with AWS Secrets Manager support.

Usage:
    uv run scripts/internal/db-migrate upgrade head          # Upgrade both databases
    uv run scripts/internal/db-migrate upgrade head results  # Upgrade results only
    uv run scripts/internal/db-migrate upgrade head metrics  # Upgrade metrics only
    uv run scripts/internal/db-migrate downgrade -1          # Downgrade both by one
    uv run scripts/internal/db-migrate current               # Show current versions

Environment variables:
    OLMO_EVAL_DB_HOST       - Database host (required)
    OLMO_EVAL_DB_PORT       - Database port (default: 5432)
    OLMO_EVAL_DB_USER       - Database user (default: postgres)
    OLMO_EVAL_DB_PASSWORD   - Database password
    OLMO_EVAL_DB_SECRET_ARN - AWS Secrets Manager ARN (used if password not set)
"""

from __future__ import annotations

import os
import subprocess
import sys


def get_connection_params() -> dict[str, str]:
    """Get database connection parameters from environment."""
    return {
        "host": os.environ.get("OLMO_EVAL_DB_HOST", ""),
        "port": os.environ.get("OLMO_EVAL_DB_PORT", "5432"),
        "user": os.environ.get("OLMO_EVAL_DB_USER", "postgres"),
        "password": os.environ.get("OLMO_EVAL_DB_PASSWORD", ""),
    }


def setup_password() -> None:
    """Fetch password from AWS Secrets Manager if needed."""
    if os.environ.get("OLMO_EVAL_DB_PASSWORD"):
        return

    arn = os.environ.get("OLMO_EVAL_DB_SECRET_ARN")
    if not arn:
        print(
            "Error: OLMO_EVAL_DB_PASSWORD not set and OLMO_EVAL_DB_SECRET_ARN not provided",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        from olmo_eval.launch.beaker.secrets import get_aws_secret_value

        password = get_aws_secret_value(arn, key="password")
        os.environ["OLMO_EVAL_DB_PASSWORD"] = password
        print("Fetched password from AWS Secrets Manager", file=sys.stderr)
    except Exception as e:
        print(f"Error: Failed to fetch password from AWS: {e}", file=sys.stderr)
        sys.exit(1)


def check_config() -> None:
    """Verify required environment variables are set."""
    if not os.environ.get("OLMO_EVAL_DB_HOST"):
        print("Error: OLMO_EVAL_DB_HOST not set", file=sys.stderr)
        sys.exit(1)


def ensure_database_exists(database: str) -> None:
    """Create database if it doesn't exist."""
    import psycopg

    params = get_connection_params()
    conninfo = (
        f"host={params['host']} port={params['port']} "
        f"user={params['user']} password={params['password']} dbname=postgres"
    )

    try:
        with psycopg.connect(conninfo, autocommit=True) as conn, conn.cursor() as cur:
            cur.execute("SELECT 1 FROM pg_database WHERE datname = %s", (database,))
            if not cur.fetchone():
                print(f"Creating database: {database}", file=sys.stderr)
                cur.execute(f'CREATE DATABASE "{database}"')
    except Exception as e:
        print(f"Error checking/creating database {database}: {e}", file=sys.stderr)
        sys.exit(1)


def run_alembic(config: str, args: list[str]) -> int:
    """Run alembic with the specified config and arguments."""
    cmd = ["uv", "run", "alembic", "-c", config] + args
    print(f"Running: {' '.join(cmd)}", file=sys.stderr)
    return subprocess.call(cmd)


def main() -> int:
    if len(sys.argv) < 2:
        print(__doc__)
        return 1

    check_config()
    setup_password()

    args = sys.argv[1:]

    # Check if last arg specifies which database
    target = None
    if args and args[-1] in ("results", "metrics"):
        target = args[-1]
        args = args[:-1]

    configs = []
    if target is None or target == "results":
        configs.append(("alembic/results.ini", "Results", "olmo_eval"))
    if target is None or target == "metrics":
        configs.append(("alembic/metrics.ini", "Metrics", "olmo_eval_metrics"))

    # Ensure databases exist before running migrations
    for _, _, database in configs:
        ensure_database_exists(database)

    exit_code = 0
    for config, name, _ in configs:
        print(f"\n=== {name} Database ===", file=sys.stderr)
        result = run_alembic(config, args)
        if result != 0:
            exit_code = result

    return exit_code


if __name__ == "__main__":
    sys.exit(main())
