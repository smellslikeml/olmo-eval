#!/bin/bash
# Setup Google Artifact Registry authentication for Podman
# Requires: GOOGLE_APPLICATION_CREDENTIALS env var containing service account JSON

set -e

if [ -z "$GOOGLE_APPLICATION_CREDENTIALS" ]; then
    echo "GOOGLE_APPLICATION_CREDENTIALS not set, skipping Artifact Registry setup"
    return 0 2>/dev/null || true  # return when sourced, no-op when executed directly
fi

echo "Setting up Artifact Registry credentials..."

# Install gcloud if not available
if ! command -v gcloud &> /dev/null; then
    echo "Installing Google Cloud SDK..."
    curl -sSL https://sdk.cloud.google.com | bash -s -- --disable-prompts --install-dir=/opt > /dev/null 2>&1
    export PATH="/opt/google-cloud-sdk/bin:$PATH"
fi

# Write credentials to temp file (gcloud needs a file path, not inline JSON)
CREDS_FILE=$(mktemp)
echo "$GOOGLE_APPLICATION_CREDENTIALS" > "$CREDS_FILE"

# Authenticate with gcloud
gcloud auth activate-service-account --key-file="$CREDS_FILE" --quiet

# Configure docker/podman credential helper for Artifact Registry
gcloud auth configure-docker us-east1-docker.pkg.dev --quiet

# Clean up
rm -f "$CREDS_FILE"

echo "Artifact Registry authentication configured"
