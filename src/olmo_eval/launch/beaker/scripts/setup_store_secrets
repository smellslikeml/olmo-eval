#!/bin/bash
# Fetch database password from AWS Secrets Manager and set PGPASSWORD.
# Called during gantry setup when --store is enabled.

set -e

if ! python -c 'from olmo_eval.launch.beaker.secrets import setup_pgpassword_from_arn; setup_pgpassword_from_arn()'; then
    exit 1
fi
source /tmp/.pgpassword
rm -f /tmp/.pgpassword
